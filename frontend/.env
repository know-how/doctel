# Base URL for the backend API.  When empty, relative URLs are used and Vite's
# dev-server proxy forwards them to http://127.0.0.1:8000 (see vite.config.ts).
# For production builds, set this to the backend origin, e.g.:
#   VITE_API_BASE_URL=https://api.doctel.zetdc.co.zw
VITE_API_BASE_URL=http://127.0.0.1:8000

# Connection monitor interval (ms) – how often the WebSocket ping/pong or
# HTTP health‑check fallback runs while the app is in use.  Default: 30000
VITE_WS_CHECK_INTERVAL_MS=30000
